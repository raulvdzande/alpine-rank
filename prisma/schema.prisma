generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}
        

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(USER)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]

  @@index([email])
}

//////////////////////////////////////////////////////
// RESORT
//////////////////////////////////////////////////////

model Resort {
  id                     String   @id @default(uuid())

  // Dataset Fields
  name                   String
  Country                String
  Continent              String?

  // PeakFlow profile fields
  region                 String?
  pisteKm                Int?
  altitudeTop            Int?
  altitudeBase           Int?
  lifts                  Int?
  dayPassPrice           Int?
  snowScore              Float?   @default(0)
  snowGuarantee          Int?     @default(0)
  snowpark               Boolean  @default(false)
  verified               Boolean  @default(false)
  pisteGreen             Int?
  pisteBlue              Int?
  pisteRed               Int?
  pisteBlack             Int?
  category               String?

  // Calculated / Cached Fields
  averageOverallRating   Float?   @default(0)
  reviewCount            Int      @default(0)

  // PeakFlow Snowflakes
  snowflakes             Int      @default(0)
  snowflakeNote          String?
  snowflakeReport        String?
  snowflakeInspected     Boolean  @default(false)
  snowflakeAwardedAt     DateTime?
  snowflakeHistory       String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  reviews                Review[]

  @@index([averageOverallRating])
  @@index([reviewCount])
  @@index([snowScore])
  @@index([snowflakes])
  @@index([snowflakeInspected])
}

//////////////////////////////////////////////////////
// REVIEW
//////////////////////////////////////////////////////

model Review {
  id          String   @id @default(uuid())

  userId      String
  resortId    String

  // Rating Categories (1-10 scale)
  terrain     Int
  snow        Int
  lifts       Int
  apres       Int
  family      Int
  value       Int
  scenery     Int

  overall     Float

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resort      Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@unique([userId, resortId])
  @@index([resortId])
}